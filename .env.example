PORT=3001
NODE_ENV=development
JWT_SECRET=your-secret-here-change-in-production
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# For local development with Firestore emulator:
FIRESTORE_EMULATOR_HOST=localhost:8181

# For production or direct Firestore access:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Production CORS: exact frontend origin(s), comma-separated, no trailing slash (e.g. https://app.sapmap.ca)
# ALLOWED_ORIGINS=https://app.sapmap.ca

# Realtime (Pusher). Get credentials at https://dashboard.pusher.com
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=us2

# Web Push (VAPID) for browser push notifications. Generate with: npx web-push generate-vapid-keys
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:support@sapmap.ca

# Optional: invite emails (Resend). If unset, invite link is only shown in the UI.
# Get an API key at https://resend.com
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=SapMap <onboarding@resend.dev>
# APP_URL=http://localhost:5173

# Contact form: where to receive messages (defaults to admin email if unset)
# CONTACT_TO_EMAIL=you@example.com
